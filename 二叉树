int main()
{
	ios::sync_with_stdio(0);
	cin.tie(nullptr);
	cin >> n;
	flag = 0;
	for (int i = 1; i <= 2 * n + 1; i++)
	{
		cin >> temp;
		a.push_back(temp);
	}
	treeNode* root = NULL;
	createTree(root);
	midOrder(root);
	cout << "\n";
	flag = 0;
	houOrder(root);
	cout << "\n";
	return 0;
